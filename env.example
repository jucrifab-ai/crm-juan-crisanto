# Copia este archivo como ".env" para probar en tu computadora.
# En Render, estas mismas variables se configuran en el panel (Environment), no en un archivo.

# Cadena de conexión de Postgres (la obtienes de Supabase o de Render Postgres)
DATABASE_URL=postgresql://usuario:password@host:5432/basededatos

# Cualquier palabra/clave secreta que tú inventes. La usarás dos veces:
# 1) aquí, 2) al registrar el webhook en Meta for Developers (campo "Verify token")
VERIFY_TOKEN=elige-una-frase-secreta

# Clave que tú inventas para que SOLO tu CRM pueda leer /api/leads
CRM_API_KEY=otra-frase-secreta-distinta

# Token de acceso de tu Página de Facebook (permiso leads_retrieval) — solo si usarás
# formularios instantáneos (Lead Ads). Se obtiene en Meta for Developers.
PAGE_ACCESS_TOKEN=

# Token de acceso de WhatsApp Cloud API — solo si usarás WhatsApp Business Platform.
WHATSAPP_TOKEN=

PORT=3000
